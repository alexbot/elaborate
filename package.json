{
  "name": "@alexbot/elaborate",
  "version": "0.1.0",
  "description": "AI Socratic interviewer that turns vague ideas into structured intent",
  "type": "module",
  "exports": {
    "./durable": {
      "types": "./dist/durable/index.d.ts",
      "import": "./dist/durable/index.js"
    },
    "./interview": {
      "types": "./dist/interview/index.d.ts",
      "import": "./dist/interview/index.js"
    },
    "./phases": {
      "types": "./dist/phases/index.d.ts",
      "import": "./dist/phases/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "import": "./dist/skill/index.js"
    }
  },
  "bin": {
    "elaborate": "./dist/skill/adapter.js"
  },
  "scripts": {
    "build": "tsc",
    "build:skill": "node scripts/build-skill.mjs",
    "deploy:skill": "node scripts/build-skill.mjs && node -e \"const fs=require('fs');fs.mkdirSync('.claude/skills/elaborate',{recursive:true});['elaborate.cjs','SKILL.md'].forEach(f=>fs.copyFileSync('dist/skill/'+f,'.claude/skills/elaborate/'+f));const map=JSON.parse(fs.readFileSync('dist/skill/elaborate.cjs.map','utf8'));map.sources=map.sources.map(s=>s.replace('../../','../../../'));fs.writeFileSync('.claude/skills/elaborate/elaborate.cjs.map',JSON.stringify(map))\" && echo Deployed to .claude/skills/elaborate/",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "eval": "vitest run --config vitest.eval.config.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "project-elaboration",
    "interview",
    "ai",
    "socratic"
  ],
  "license": "MIT",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@types/node": "^20.0.0",
    "ai": "^6.0.168",
    "esbuild": "^0.27.3",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "dependencies": {
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
