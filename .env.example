# T3 evaluation harness — model configuration
# Format: provider:model-id (e.g., anthropic:claude-sonnet-4-6-20250514)
# Supported providers: anthropic, openai, google, openrouter

ELABORATE_MODEL=anthropic:claude-haiku-4-5-20251001
JUDGE_MODEL=anthropic:claude-sonnet-4-6-20250514
SH_MODEL=anthropic:claude-haiku-4-5-20251001

# API keys — set the one(s) matching your provider prefix above
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_PROVIDER=

# Driver mode: "api" (default) or "cli" (uses Claude Code CLI)
# T3_DRIVER=api

# CLI driver model overrides (only when T3_DRIVER=cli)
# CLI_ELABORATE_MODEL=
# CLI_JUDGE_MODEL=
# CLI_SH_MODEL=
